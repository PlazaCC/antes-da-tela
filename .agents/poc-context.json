    "storage": "Supabase Storage + Cloudflare CDN",
    "pdf": "pdfjs-dist (next/dynamic, ssr: false)",
    "state": "Zustand",
    "cache": "TanStack Query + superjson",
    "ui": "shadcn/ui + Radix UI + Tailwind v3",
    "email": "Resend",
    "analytics": "PostHog",
    "errors": "Sentry",
    "pkg_manager": "Yarn 4 (Berry)"
  },

  "critical_paths": {
    "schema": "server/db/schema.ts",
    "router_root": "server/api/root.ts",
    "trpc_init": "trpc/init.ts",
    "trpc_client": "trpc/client.tsx",
    "trpc_server": "trpc/server.tsx",
    "supabase_client": "lib/supabase/client.ts",
    "supabase_server": "lib/supabase/server.ts",
    "authenticated_layout": "app/(authenticated)/layout.tsx",
    "trpc_handler": "app/api/trpc/[trpc]/route.ts",
    "globals_css": "app/globals.css",
    "tailwind_config": "tailwind.config.ts",
    "components_ui": "components/ui/",
    "task_files": ".agents/tasks/"
  },

  "conventions": {
    "classname": "cn() from @/lib/utils",
    "upload": "always client-side to Supabase Storage (Vercel 10s timeout)",
    "ssr_prefetch": "trpc + HydrateClient from @/trpc/server",
    "client_query": "useTRPC() from @/trpc/client",
    "validation": "Zod schema shared between tRPC input and zodResolver",
    "server_component": "createServerClient from @supabase/ssr",
    "client_component": "createBrowserClient from @supabase/ssr",
    "tailwind_version": "v3 — no v4 syntax",
    "package_install": "yarn add — never npm install",
    "tokens_format": "CSS vars use HSL channels (no hex), Tailwind wraps with hsl(var(...))",
    "db_migrations": "DATABASE_URL_UNPOOLED (port 5432) for migrate only",
    "supabase_cli": "Always use CLI (npx supabase@latest db query --linked) for writes — MCP is read-only",
    "select_discipline": "Always use explicit column selection in queries that cross RSC boundary — never select('*') for data passed to Client Components",
    "mutation_page_capture": "In TanStack Query mutations, capture page/volatile state at submit time via per-call onSuccess, not in mutationOptions closure"
  },

  "validation_commands": {
    "build": "yarn build",
    "lint": "yarn lint",
    "db_generate": "yarn drizzle-kit generate",
    "db_migrate": "yarn drizzle-kit migrate",
    "dev": "yarn dev"
  },

