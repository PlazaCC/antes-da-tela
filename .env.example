# Corepack Vercel https://vercel.com/docs/builds/configure-a-build#corepack
ENABLE_EXPERIMENTAL_COREPACK=1

# App URL (used for metadataBase / OG links)
NEXT_PUBLIC_APP_URL=https://antes-da-tela.vercel.app

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Posthog
NEXT_PUBLIC_POSTHOG_TOKEN=your-posthog-token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend
RESEND_API_KEY=your-resend-api-key
TEST_RESEND_TO=your-test-email

# Sentry
# `SENTRY_AUTH_TOKEN` is used by the Sentry build plugin (source map upload).
# Keep it secret and set it in CI (Vercel/Netlify) — do not commit the token.
SENTRY_AUTH_TOKEN=your-sentry-api-key
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Public Sentry variables for client-side SDK (optional but required to capture browser errors)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
