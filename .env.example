# Corepack Vercel https://vercel.com/docs/builds/configure-a-build#corepack
ENABLE_EXPERIMENTAL_COREPACK=1

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Supabase service role key (SERVER ONLY)
# Set this in your deployment provider's server environment (e.g. Vercel "Environment Variables" target: Production/Preview).
# NEVER expose this value to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password
DATABASE_PASSWORD=your-database-password

# Database — transaction pooler (runtime, used by Drizzle)
DATABASE_URL=postgresql://postgres:${DATABASE_PASSWORD}@db.rbesxenumiuijosbntzp.supabase.co:6543/postgres?pgmode=transaction

# Database — session pooler (migrations only)
DATABASE_URL_UNPOOLED=postgresql://postgres:${DATABASE_PASSWORD}@db.rbesxenumiuijosbntzp.supabase.co:6543/postgres

# Posthog
NEXT_PUBLIC_POSTHOG_TOKEN=your-posthog-token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend
RESEND_API_KEY=your-resend-api-key

# Sentry
SENTRY_AUTH_TOKEN=your-sentry-api-key